{
  "name": "fixed-platform-puzzle",
  "version": "0.4.2",
  "description": "Grid-based puzzle game for Poki and CrazyGames",
  "private": true,
  "scripts": {
    "dev": "webpack serve --config webpack.config.js --mode development",
    "build": "webpack --config webpack.config.js --mode production",
    "analyze": "webpack --config webpack.config.js --mode production --env analyze",
    "size": "du -sh dist/ && ls -lh dist/",
    "validate-levels": "tsx scripts/validate-levels.ts",
    "bake-levels": "tsx scripts/bake-v2.ts",
    "bake-legacy": "tsx scripts/bake-legacy.ts",
    "package:poki": "tsx scripts/package.ts poki",
    "package:crazygames": "tsx scripts/package.ts crazygames",
    "package:gamedistribution": "tsx scripts/package.ts gamedistribution",
    "package:playgama": "tsx scripts/package.ts playgama",
    "package:itch": "tsx scripts/package.ts itch",
    "package:discord": "tsx scripts/package.ts discord",
    "build:discord": "webpack --config webpack.config.js --mode production --env target=discord",
    "release": "tsx scripts/release.ts"
  },
  "keywords": [
    "phaser",
    "puzzle",
    "game",
    "poki",
    "crazygames"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.0.0",
    "phaser": "^4.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "compression-webpack-plugin": "^12.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "html-webpack-plugin": "^5.6.7",
    "terser-webpack-plugin": "^5.5.0",
    "ts-loader": "^9.5.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
