# Discord Activity credentials (target = discord)
# Get these from https://discord.com/developers/applications -> your app -> OAuth2

# Public client id — exposed to browser, injected at build time via webpack DefinePlugin.
VITE_DISCORD_CLIENT_ID=

# Secret — used only by server/server.js for OAuth2 token exchange (Phase 2).
# NEVER expose to client. Keep this file in .gitignore.
DISCORD_CLIENT_SECRET=

# Optional override for server port (default 3001).
# PORT=3001
